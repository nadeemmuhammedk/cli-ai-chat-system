# .gitignore - Files to exclude from git repository

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# Environment files
.env
.env.local
.env.*.local
*.env

# Temporary files
*.tmp
*.temp
.temp/
.cache/

# Build artifacts
dist/
build/
*.tgz

# Testing
coverage/
.nyc_output/

# Editor backup files
*~
\#*\#
.\#*

# Session-specific (generated by users, not by package)
chats/
unnamed_projects/
.cli-ai-chat/sessions.json
.cli-ai-chat/active-session.txt

# Test artifacts
test-folder/
